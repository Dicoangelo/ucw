      "node-1": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["How do I use SQLite with Python?"]},
          "create_time": 1710100010.0
        }
      },
      "node-2": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["You can use the sqlite3 module from the standard library. Import it, create a connection with sqlite3.connect(), and use cursors to execute SQL queries."]},
          "create_time": 1710100020.0
        }
      },
      "node-3": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["What is WAL mode?"]},
          "create_time": 1710100030.0
        }
      },
      "node-4": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["WAL (Write-Ahead Logging) is a journaling mode in SQLite that allows concurrent reads and writes. Enable it with PRAGMA journal_mode=wal."]},
          "create_time": 1710100040.0
        }
      },
      "node-5": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["How about schema migrations?"]},
          "create_time": 1710100050.0
        }
      },
      "node-6": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["For schema migrations in SQLite, you can track applied versions in a migrations table and run ALTER TABLE statements sequentially. Tools like Alembic also work."]},
          "create_time": 1710100060.0
        }
      }
    }
