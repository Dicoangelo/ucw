    "create_time": 1710200000.0,
    "update_time": 1710201000.0,
    "mapping": {
      "node-1": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["Explain the Model Context Protocol"]},
          "create_time": 1710200010.0
        }
      },
      "node-2": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["The Model Context Protocol (MCP) is a standard for connecting AI assistants to external tools and data sources. It uses JSON-RPC over stdio transport."]},
          "create_time": 1710200020.0
        }
      },
      "node-3": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["How does tool calling work in MCP?"]},
          "create_time": 1710200030.0
        }
      },
      "node-4": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["In MCP, the client sends a tools/call request with a tool name and arguments. The server executes the tool and returns results as content blocks."]},
          "create_time": 1710200040.0
        }
      },
      "node-5": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["Can MCP handle cognitive capture?"]},
          "create_time": 1710200050.0
        }
      },
      "node-6": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["Yes, by intercepting the MCP message stream you can capture every cognitive interaction — tool calls, prompts, and responses — building a Universal Cognitive Wallet."]},
          "create_time": 1710200060.0
        }
      }
    }
  }
