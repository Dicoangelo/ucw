      "node-2": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["What is gradient descent?"]},
          "create_time": 1710000010.0
        }
      },
      "node-3": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["Gradient descent is an optimization algorithm used to minimize a function by iteratively moving in the direction of steepest descent."]},
          "create_time": 1710000020.0
        }
      },
      "node-4": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["Can you explain the learning rate?"]},
          "create_time": 1710000030.0
        }
      },
      "node-5": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["The learning rate is a hyperparameter that controls how much the model weights are updated during training. A high learning rate can cause overshooting, while a low one leads to slow convergence."]},
          "create_time": 1710000040.0
        }
      },
      "node-6": {
        "message": null
      },
      "node-7": {
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["What about batch size?"]},
          "create_time": 1710000050.0
        }
      },
      "node-8": {
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["Batch size determines the number of training samples used in one forward/backward pass. Larger batches are more stable but use more memory."]},
          "create_time": 1710000060.0
        }
      }
    }
